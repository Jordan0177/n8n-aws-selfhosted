    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n   staticData.alerts = staticData.alerts || {};\n   const results = [];\n   const items = $input.all();\n   for (let i = 0; i < items.length; i++) {\n     const city = $('Define cities').itemMatching(i).json.city;\n     const temp = items[i].json.current.temperature_2m;\n     const wind = items[i].json.current.wind_speed_10m;\n     const isAlert = wind > 30 || temp < 0;   // real thresholds\n     const wasAlert = staticData.alerts[city] || false;\n     if (isAlert !== wasAlert) {\n       results.push({ json: { city, temp, wind,\n         status: isAlert ? 'ALERT' : 'CLEARED',\n         daily: items[i].json.daily } });\n     }\n     staticData.alerts[city] = isAlert;\n   }\n   return results;"
      },
