      "parameters": {
        "jsCode": "const topic = $('Grab Idea').first().json.Topic;\nreturn [\n  { json: { language: 'EN', voice_id: 'AtEtJxZcH8TRn1nNhXol', topic } },\n  { json: { language: 'DE', voice_id: 'cdzqtV2ttnDyTZnMZ5UU', topic } },\n];"
