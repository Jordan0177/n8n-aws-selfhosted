    {
      "parameters": {
        "jsCode": "const movies = $input.all().map(i => i.json.movie);\n\nconst failed = movies.find(m => m && m.status === 'error');\nif (failed) {\n  throw new Error('Render failed: ' + JSON.stringify(failed));\n}\n\nif ($runIndex > 45) {\n  throw new Error(`Renders not finished after ${$runIndex} polls (~15 min). Statuses: ${movies.map(m => m?.status).join(', ')}`);\n}\n\nconst done = movies.every(m => m && m.status === 'done');\nreturn [{ json: {\n  done,\n  url_en: movies[0]?.url ?? '',\n  url_de: movies[1]?.url ?? ''\n} }];"
      },
