        "jsonBody": "={\n  \"resolution\": \"custom\",\n  \"width\": 1080,\n  \"height\": 1920,\n  \"quality\": \"high\",\n  \"scenes\": [\n    {\n      \"elements\": [\n        {\n          \"type\": \"video\",\n          \"src\": \"{{ $('Aggregate').first().json.clips[0] }}\",\n          \"start\": 0,\n          \"duration\": 10,\n          \"resize\": \"cover\",\n          \"keyframes\": [\n            { \"time\": 0,  \"zoom\": 0,   \"easing\": \"linear\" },\n            { \"time\": 5,  \"zoom\": 2,   \"easing\": \"ease-out-cubic\" },\n            { \"time\": 10, \"zoom\": 3.5, \"easing\": \"ease-in-out-sine\" }\n          ]\n        },\n        {\n          \"type\": \"video\",\n          \"src\": \"{{ $('Aggregate').first().json.clips[1] }}\",\n          \"start\": 10,\n          \"duration\": 10,\n          \"resize\": \"cover\",\n          \"keyframes\": [\n            { \"time\": 0,  \"zoom\": 1,   \"easing\": \"linear\" },\n            { \"time\": 2,  \"zoom\": 3,   \"easing\": \"ease-out-quint\" },\n            { \"time\": 6,  \"zoom\": 1.5, \"easing\": \"ease-in-out-sine\" },\n            { \"time\": 10, \"zoom\": 3.5, \"easing\": \"linear\" }\n          ]\n        },\n        {\n          \"type\": \"video\",\n          \"src\": \"{{ $('Aggregate').first().json.clips[2] }}\",\n          \"start\": 20,\n          \"duration\": -2,\n          \"resize\": \"cover\",\n          \"keyframes\": [\n            { \"time\": \"0%\",   \"zoom\": 3.5, \"easing\": \"linear\" },\n            { \"time\": \"60%\",  \"zoom\": 1,   \"easing\": \"ease-in-out-cubic\" },\n            { \"time\": \"100%\", \"zoom\": 0,   \"easing\": \"linear\" }\n          ]\n        },\n        {\n          \"type\": \"audio\",\n          \"src\": \"{{ $('Upload to Drive').item.json.webContentLink }}\"\n        },\n        {\n          \"type\": \"text\",\n          \"text\": \"{{ $('Parse scripts (JSON)').item.json.hook_text }}\",\n          \"start\": 0,\n          \"duration\": 3,\n          \"fade-in\": 0.3,\n          \"fade-out\": 0.3,\n          \"settings\": {\n            \"font-family\": \"Oswald\",\n            \"font-size\": \"92px\",\n            \"font-weight\": \"700\",\n            \"font-color\": \"#FFFFFF\",\n            \"text-shadow\": \"0px 4px 14px rgba(0,0,0,0.9)\",\n            \"text-align\": \"center\",\n            \"text-transform\": \"uppercase\",\n            \"vertical-position\": \"top\",\n            \"horizontal-position\": \"center\"\n          }\n        }\n      ]\n    }\n  ],\n  \"elements\": [\n    { \"type\": \"audio\", \"src\": \"https://drive.google.com/uc?export=download&id=YOUR_DRIVE_AUDIO_FILE_ID\", \"volume\": 0.25, \"duration\": -2 },\n    { \"type\": \"subtitles\", \"src\": \"{{ $('Upload to Drive').item.json.webContentLink }}\", \"settings\": { \"style\": \"classic-progressive\", \"font-family\": \"Oswald\", \"font-size\": 64, \"word-color\": \"#FFFFFF\", \"line-color\": \"#FFFFFF\", \"outline-color\": \"#000000\", \"outline-width\": 6, \"position\": \"center-center\" } }\n  ]\n}",
