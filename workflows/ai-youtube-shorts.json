      "id": "9c8c9f18-2d61-4cab-be70-2401d9878c06",
      "name": "Language fan-out"
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map((item, i) => {\n  let raw = (item.json.output || '').toString();\n  raw = raw.replace(/```json/gi, '').replace(/```/g, '').trim();\n\n  // Keep only the outermost JSON object (drops any prose before/after it)\n  const first = raw.indexOf('{');\n  const last = raw.lastIndexOf('}');\n  if (first === -1 || last === -1 || last < first) {\n    throw new Error('No JSON object found in model output: ' + raw.slice(0, 300));\n  }\n  raw = raw.slice(first, last + 1);\n\n  let parsed;\n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    throw new Error('JSON parse failed: ' + e.message + ' | raw: ' + raw.slice(0, 500));\n  }\n\n  const meta = $('Language fan-out').all()[i].json;\n  return {\n    json: {\n      script: parsed.script,\n      hook_text: parsed.hook_text || parsed.title || '',\n      title: parsed.title || '',\n      description: parsed.description || '',\n      fact_check_flags: parsed.fact_check_flags || [],\n      language: meta.language,\n      voice_id: meta.voice_id,\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3776,
        128
      ],
      "id": "c246be12-e72b-49fd-aa18-c5ec9095d26f",
      "name": "Parse scripts (JSON)"
    },
    {
      "parameters": {
        "jsCode": "const text = $input.first().json.output;\nconst prompts = text\n  .split(/\\n+/)                      // any number of newlines\n  .map(p => p.trim())\n  .filter(p => p.length > 20)       // drops numbering, headers, stray lines\n  .slice(0, 3);\n\nif (prompts.length < 3) {\n  throw new Error(`Expected 3 prompts, got ${prompts.length}. Raw output: ${text.slice(0, 200)}`);\n}\n\nreturn prompts.map(p => ({ json: { prompt: p } }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        976,
        128
      ],
      "id": "3f604e3a-8fe0-485e-ba2c-a9a1ad13f443",
      "name": "Split image prompts"
